{{- $posts := where .Site.RegularPages "Section" "posts" -}}
[
{{- range $i, $p := $posts -}}
  {{- if $i }},{{ end }}
  {
    "title": {{ $p.Title | jsonify }},
    "address": {{ $p.Params.address | default "" | jsonify }},
    "lat": {{ $p.Params.lat | default 0 }},
    "lng": {{ $p.Params.lng | default 0 }},
    "image": {{ $p.Params.image | default "" | jsonify }},
    "review": {{ $p.Plain | truncate 200 | jsonify }},
    "serious": {{ if $p.Params.serious }}true{{ else }}false{{ end }},
    "permalink": {{ $p.RelPermalink | jsonify }}
  }
{{- end }}
]
